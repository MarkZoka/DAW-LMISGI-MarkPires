<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
    <xsl:output method="xml" indent="yes" encoding="UTF-8"/>

    <xsl:template match="/">
        <company_structure>
            <employees>
                <xsl:for-each select="resultset/row">
                    <employee id="{field[@name='employeeNumber']}">
                        <personal_info>
                            <name><xsl:value-of select="field[@name='firstName']"/> <xsl:value-of select="field[@name='lastName']"/></name>
                            <role><xsl:value-of select="field[@name='jobTitle']"/></role>
                        </personal_info>
                        <contact>
                            <email><xsl:value-of select="field[@name='email']"/></email>
                            <ext><xsl:value-of select="field[@name='extension']"/></ext>
                        </contact>
                        <office_details>
                            <city><xsl:value-of select="field[@name='ofCity']"/></city>
                            <address><xsl:value-of select="field[@name='ofAdd1']"/></address>
                            <country><xsl:value-of select="field[@name='ofCountry']"/></country>
                        </office_details>
                    </employee>
                </xsl:for-each>
            </employees>
        </company_structure>
    </xsl:template>
</xsl:stylesheet>
