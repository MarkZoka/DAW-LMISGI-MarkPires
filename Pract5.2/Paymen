<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
    <xsl:output method="xml" indent="yes" encoding="UTF-8"/>

    <xsl:template match="/">
        <financial_records>
            <all_payments>
                <xsl:for-each select="resultset/row">
                    <payment_entry>
                        <transaction>
                            <check_number><xsl:value-of select="field[@name='checkNumber']"/></check_number>
                            <date><xsl:value-of select="field[@name='paymentDate']"/></date>
                            <amount currency="USD"><xsl:value-of select="field[@name='amount']"/></amount>
                        </transaction>
                        <client_info>
                            <id><xsl:value-of select="field[@name='customerNumber']"/></id>
                            <name><xsl:value-of select="field[@name='customerName']"/></name>
                        </client_info>
                    </payment_entry>
                </xsl:for-each>
            </all_payments>
        </financial_records>
    </xsl:template>
</xsl:stylesheet>