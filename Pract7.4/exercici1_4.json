SELECT 
    JSON_UNQUOTE(JSON_EXTRACT(t.json_data, '$.account_id')) AS account_id,
    JSON_UNQUOTE(JSON_EXTRACT(t.json_data, '$.amount')) AS amount
FROM transactions t
INNER JOIN accounts a 
ON JSON_UNQUOTE(JSON_EXTRACT(t.json_data, '$.account_id')) = JSON_UNQUOTE(JSON_EXTRACT(a.json_data, '$.account_id'));